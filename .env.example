# Copy to .env. Never commit real secrets.
APP_ENV=development
LOG_LEVEL=INFO
LEGACY_DATABASE_URL=postgresql://legacy:legacy@db-legacy:5432/legacy_crm
KNOWLEDGE_DATABASE_URL=postgresql://knowledge:knowledge@db-knowledge:5432/knowledge_platform

# ollama (local), groq (cloud demo), or rules (deterministic/offline evaluation)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://host.docker.internal:11434
GROQ_API_KEY=
API_AUTH_TOKEN=
GROQ_MODEL=openai/gpt-oss-20b
# Set provider-equivalent rates to estimate cost even when using a free tier.
LLM_INPUT_COST_PER_MILLION_USD=0.0
LLM_OUTPUT_COST_PER_MILLION_USD=0.0

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CONFIDENCE_THRESHOLD=0.80
INTEGRATION_TIMEOUT_SECONDS=4.0
CHAOS_STATE_PATH=/app/chaos/state.json
BACKEND_URL=http://backend:8000
BACKEND_API_KEY=
GRAFANA_URL=http://localhost:3000/d/agent-overview

OTEL_SERVICE_NAME=agent-reliability-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

POSTGRES_LEGACY_USER=legacy
POSTGRES_LEGACY_PASSWORD=legacy
POSTGRES_LEGACY_DB=legacy_crm
POSTGRES_KNOWLEDGE_USER=knowledge
POSTGRES_KNOWLEDGE_PASSWORD=knowledge
POSTGRES_KNOWLEDGE_DB=knowledge_platform
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

